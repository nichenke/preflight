.worktrees/
.claude/*.local.md
.claude/*.local.json

# spec-kit install artifacts — populated by `specify preset add --dev` and
# `specify extension add --dev`. Source of truth lives at presets/preflight/
# and extensions/preflight/ at the repo root; these are install-time copies.
.specify/extensions/preflight/
.specify/presets/preflight/
.claude/skills/speckit-preflight-review/

# spec-kit active-feature pointer — populated by /speckit.specify, pins
# the worktree to one feature. Local-only; committing it would force all
# branches to operate on whichever feature happened to be current.
.specify/feature.json

# Skill eval run artifacts
skills/*-workspace/

# uv dev environment (uv.lock is committed for reproducibility)
.venv/
__pycache__/
*.pyc

# Research cache — cloned peer-framework repos for rule-design research
# (see .claude/rules/rule-design.md). Local-only; do not commit.
cache/
